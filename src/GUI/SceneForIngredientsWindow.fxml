<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="myIngredientsAnchor" prefHeight="551.0" prefWidth="385.0" stylesheets="@styleSheet.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.IngredientsController">
   <children>
      <ImageView fitHeight="114.0" fitWidth="210.0" layoutX="68.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../Images/myIngr3.png" />
         </image>
      </ImageView>
      <StackPane fx:id="ingredientListStackPane" layoutX="36.0" layoutY="102.0" prefHeight="299.0" prefWidth="315.0">
         <children>

            <ListView fx:id="ingredientList" layoutX="8.0" layoutY="8.0" prefHeight="254.0" prefWidth="297.0" />
         </children>
      </StackPane>
      <Button fx:id="removeIngredientButton" layoutX="170.0" layoutY="479.0" mnemonicParsing="false" onAction="#removeIngredient" prefHeight="35.0" prefWidth="43.0" style="-fx-background-radius: 10;">
         <graphic>
            <ImageView fitHeight="27.0" fitWidth="31.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../Images/remove.png" />
               </image>
            </ImageView>
         </graphic>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
      <Pane fx:id="addingredientPane" layoutX="46.0" layoutY="424.0" prefHeight="36.0" prefWidth="217.0" style="-fx-background-radius: 15;">
         <children>
      
                <TextField fx:id="newIngredientField" layoutX="11.0" layoutY="4.0" prefHeight="28.0" prefWidth="159.0" promptText="Enter ingredient" style="-fx-background-radius: 15 0 0 15;" />
         </children></Pane>

          <Button fx:id="addIngredientButton" layoutX="272.0" layoutY="424.0" onAction="#addIngredient" prefHeight="36.0" prefWidth="65.0" style="-fx-background-radius: 15;" text="Add" textFill="#646f62">
         <font>
            <Font name="Verdana Bold" size="11.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <ImageView fitHeight="103.0" fitWidth="177.0" layoutX="205.0" layoutY="14.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../Images/cream.png" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
