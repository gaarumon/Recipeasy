<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="newRecipeAnchor" prefHeight="551.0" prefWidth="385.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.NewRecipeController">
   <children>
      <StackPane fx:id="newRecipeInstructionsTextStackPane" layoutX="24.0" layoutY="350.0" prefHeight="127.0" prefWidth="338.0">
         <children>
            <TextArea fx:id="newRecipeInstructionsText" prefHeight="104.0" prefWidth="314.0" promptText="1. Write your instructions here" style="-fx-background-radius: 15;" />
         </children>
      </StackPane>
      <StackPane fx:id="ingredientsNewRecipeListViewStackPane" layoutX="24.0" layoutY="188.0">
         <children>
            <ListView fx:id="ingredientsNewRecipeListView" prefHeight="121.0" prefWidth="338.0" style="-fx-background-radius: 15;" />
         </children>
      </StackPane>
      <Button fx:id="cancelNewRecipeButton" layoutX="224.0" layoutY="498.0" mnemonicParsing="false" style="-fx-background-radius: 10;" text="Cancel" textFill="#f5f4e4">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
      <Button fx:id="saveRecipeButton" layoutX="91.0" layoutY="498.0" mnemonicParsing="false" onAction="#pressedSaveRecipeButton" prefHeight="25.0" prefWidth="88.0" style="-fx-background-radius: 10;" text="Save Recipe" textFill="#5a6558">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
      <ImageView fitHeight="135.0" fitWidth="256.0" layoutX="68.0" layoutY="-32.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../Images/yourRules.png" />
         </image>
      </ImageView>
      <TextField fx:id="nameNewRecipeField" layoutX="29.0" layoutY="103.0" prefHeight="26.0" prefWidth="200.0" promptText="Spaghetti Bolognese" style="-fx-background-radius: 15;" />
      <StackPane fx:id="ingredientAmountAddStackPane" layoutX="29.0" layoutY="147.0" prefHeight="26.0" prefWidth="331.0" />
      <TextField fx:id="ingredientNewRecipeField" layoutX="30.0" layoutY="147.0" prefHeight="26.0" prefWidth="173.0" promptText="Spaghetti" style="-fx-background-radius: 15 0 0 15;" />
      <TextField fx:id="measurementNewRecipeField" layoutX="200.0" layoutY="147.0" prefHeight="26.0" prefWidth="103.0" promptText="500g" />
      <Button fx:id="addIngredientNewRecipe" layoutX="303.0" layoutY="147.0" mnemonicParsing="false" onAction="#addIngredient" prefHeight="25.0" prefWidth="59.0" style="-fx-background-radius: 0 15 15 0;" text="Add">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
      <Label layoutX="29.0" layoutY="80.0" prefHeight="19.0" prefWidth="160.0" text="Choose a Recipe Name:" textFill="#5a6558">
         <font>
            <Font name="Avenir Next Condensed Bold" size="15.0" />
         </font>
      </Label>
      <Label layoutX="30.0" layoutY="323.0" prefHeight="17.0" prefWidth="141.0" text="Instructions:" textFill="#5a6558">
         <font>
            <Font name="Avenir Next Condensed Bold" size="15.0" />
         </font>
      </Label>
      <Label layoutX="193.0" layoutY="500.0" prefHeight="19.0" prefWidth="14.0" text="or" textFill="#5a6558">
         <font>
            <Font name="Avenir Next Condensed Bold" size="15.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
