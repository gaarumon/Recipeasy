<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="340.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ShoppingListController">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" prefHeight="460.0" prefWidth="300.0" spacing="10.0">
            <children>
                <Label text="Shopping list" />
                <Label fx:id="statusLabel" prefHeight="20.0" prefWidth="300.0" />
                <HBox prefHeight="35.0" prefWidth="300.0" spacing="8.0">
                    <children>
                        <TextField fx:id="addIngredientField" prefHeight="35.0" prefWidth="215.0" promptText="Add ingredient..." />
                        <Button fx:id="addButton" mnemonicParsing="false" onAction="#pressedAddButton" prefHeight="35.0" prefWidth="77.0" text="Add" />
                    </children>
                </HBox>
                <ListView fx:id="shoppingListView" prefHeight="290.0" prefWidth="300.0" />
                <HBox prefHeight="35.0" prefWidth="300.0" spacing="8.0">
                    <children>
                        <Button fx:id="removeButton" mnemonicParsing="false" onAction="#pressedRemoveButton" prefHeight="35.0" prefWidth="146.0" text="Remove selected" />
                        <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#pressedRefreshButton" prefHeight="35.0" prefWidth="146.0" text="Refresh" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>