<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="shoppingListAnchor" prefHeight="528.0" prefWidth="377.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ShoppingListController">
    <children>
            <Button fx:id="removeButton" layoutX="221.0" layoutY="457.0" mnemonicParsing="false" onAction="#pressedRemoveButton" prefHeight="43.0" prefWidth="59.0" style="-fx-background-radius: 15;">
         <graphic>
            <ImageView fitHeight="29.0" fitWidth="31.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../Images/remove.png" />
               </image>
            </ImageView>
         </graphic>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
          <Label fx:id="statusLabel" layoutX="39.0" layoutY="64.0" prefHeight="20.0" prefWidth="300.0" />
            <TextField fx:id="addIngredientField" layoutX="39.0" layoutY="91.0" prefHeight="35.0" prefWidth="229.0" promptText="Add ingredient..." style="-fx-background-radius: 15;" />
            <Button fx:id="addButton" layoutX="280.0" layoutY="91.0" mnemonicParsing="false" onAction="#pressedAddButton" prefHeight="35.0" prefWidth="59.0" style="-fx-background-radius: 15;" text="Add" textFill="#7b8377">
         <font>
            <Font name="Avenir Next Condensed Bold" size="13.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <StackPane fx:id="shoppingListStackPane" layoutX="39.0" layoutY="146.0" prefHeight="282.0" prefWidth="300.0">
         <children>
                <ListView fx:id="shoppingListView" prefHeight="290.0" prefWidth="300.0" />
         </children>
      </StackPane>
            <Button fx:id="refreshButton" layoutX="83.0" layoutY="457.0" mnemonicParsing="false" onAction="#pressedRefreshButton" prefHeight="43.0" prefWidth="106.0" style="-fx-background-radius: 15;" text="Refresh" textFill="#7b8377">
         <font>
            <Font name="Avenir Next Condensed Bold" size="15.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <ImageView fitHeight="132.0" fitWidth="324.0" layoutX="70.0" layoutY="-23.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../Images/myShoppingListPic.png" />
         </image>
      </ImageView>
    </children>
</AnchorPane>
