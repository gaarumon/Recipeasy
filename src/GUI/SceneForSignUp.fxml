<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="signupBackground" prefHeight="280.0" prefWidth="284.0" stylesheets="@styleSheet.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.LogInSignUpController">
   <children>
      <TextField fx:id="signUpUsername" layoutX="61.0" layoutY="150.0" prefHeight="33.0" prefWidth="162.0" promptText="Input a username" AnchorPane.bottomAnchor="124.0" AnchorPane.leftAnchor="61.0" AnchorPane.rightAnchor="61.0" AnchorPane.topAnchor="150.0" />
      <PasswordField fx:id="signUpPassword" layoutX="61.0" layoutY="204.0" prefHeight="33.0" prefWidth="162.0" promptText="Input a password" AnchorPane.bottomAnchor="70.0" AnchorPane.leftAnchor="61.0" AnchorPane.rightAnchor="61.0" AnchorPane.topAnchor="204.0" />
      <Label fx:id="chooseUsernameLabel" layoutX="62.0" layoutY="118.0" prefHeight="17.0" prefWidth="160.0" text="Choose a username:" textFill="#575c6b" AnchorPane.bottomAnchor="141.0" AnchorPane.leftAnchor="62.0" AnchorPane.rightAnchor="62.0" AnchorPane.topAnchor="118.0" />
      <Label fx:id="choosePasswordLabel" layoutX="62.0" layoutY="187.0" prefHeight="17.0" prefWidth="160.0" text="Choose a password:" textFill="#575c6b" />
      <Button fx:id="signUpButton2" layoutX="111.0" layoutY="247.0" mnemonicParsing="false" onAction="#handleSignUp" text="Sign up!" textFill="#575c6b" />
      <ImageView fitHeight="115.0" fitWidth="186.0" layoutX="49.0" layoutY="14.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../Images/recipeasyLogo.png" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
