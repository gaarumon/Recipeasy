<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="myIngredientsAnchor" prefHeight="551.0" prefWidth="385.0" stylesheets="@styleSheet.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.IngredientsController">
   <children>
      <ImageView fitHeight="146.0" fitWidth="231.0" layoutX="42.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../Images/myIngr3.png" />
         </image>
      </ImageView>
      <StackPane fx:id="ingredientListStackPane" layoutX="35.0" layoutY="162.0" prefHeight="262.0" prefWidth="315.0">
         <children>

            <ListView fx:id="ingredientList" layoutX="8.0" layoutY="8.0" prefHeight="254.0" prefWidth="297.0" />
         </children>
      </StackPane>
      <Button fx:id="removeIngredientButton" layoutX="171.0" layoutY="439.0" mnemonicParsing="false" onAction="#removeIngredient" prefHeight="35.0" prefWidth="43.0" style="-fx-background-radius: 10;">
         <graphic>
            <ImageView fitHeight="27.0" fitWidth="31.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../Images/remove.png" />
               </image>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </ImageView>
         </graphic>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
      <Pane fx:id="addingredientPane" layoutX="42.0" layoutY="107.0" prefHeight="36.0" prefWidth="204.0" style="-fx-background-radius: 15;">
         <children>
      
                <TextField fx:id="newIngredientField" layoutX="11.0" layoutY="4.0" prefHeight="28.0" prefWidth="159.0" promptText="Enter ingredient" style="-fx-background-radius: 15 0 0 15;" />
         </children></Pane>

          <Button fx:id="addIngredientButton" layoutX="258.0" layoutY="107.0" onAction="#addIngredient" prefHeight="36.0" prefWidth="81.0" style="-fx-background-radius: 15;" text="Add" textFill="#646f62">
         <font>
            <Font name="Verdana Bold" size="11.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <ImageView fitHeight="93.0" fitWidth="170.0" layoutX="215.0" layoutY="22.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../Images/cream.png" />
         </image>
      </ImageView>
      <Button fx:id="theLongButton" layoutX="47.0" layoutY="489.0" mnemonicParsing="false" onAction="#handleIngredientRecipesButton" prefHeight="36.0" prefWidth="291.0" style="-fx-background-radius: 15;" text="SHOW RECIPES BASED ON MY INGREDIENTS!" textFill="#646f62">
         <font>
            <Font name="Georgia" size="11.0" />
         </font>
      </Button>
   </children>
   <cursor>
      <Cursor fx:constant="HAND" />
   </cursor>
</AnchorPane>
