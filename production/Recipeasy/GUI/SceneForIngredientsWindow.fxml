<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="myIngredientsAnchor" prefHeight="465.0" prefWidth="383.0" stylesheets="@styleSheet.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.IngredientsController">
   <children>
      <ImageView fitHeight="114.0" fitWidth="210.0" layoutX="86.0" layoutY="-19.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../Images/myIngr3.png" />
         </image>
      </ImageView>
      <StackPane fx:id="ingredientListStackPane" layoutX="36.0" layoutY="61.0">
         <children>

            <ListView fx:id="ingredientList" layoutX="8.0" layoutY="8.0" prefHeight="254.0" prefWidth="297.0" />
         </children>
      </StackPane>
      <Button fx:id="removeIngredientButton" layoutX="170.0" layoutY="409.0" mnemonicParsing="false" onAction="#removeIngredient" prefHeight="35.0" prefWidth="43.0" style="-fx-background-radius: 10;">
         <graphic>
            <ImageView fitHeight="27.0" fitWidth="31.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../Images/remove.png" />
               </image>
            </ImageView>
         </graphic>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
      <Pane fx:id="addingredientPane" layoutX="30.0" layoutY="358.0" prefHeight="36.0" prefWidth="323.0" style="-fx-background-radius: 15;">
         <children>
      
                <TextField fx:id="newIngredientField" prefHeight="36.0" prefWidth="198.0" promptText="Enter ingredient" style="-fx-background-radius: 15 0 0 15;" />
      
                <Button fx:id="addIngredientButton" layoutX="198.0" onAction="#addIngredient" prefHeight="36.0" prefWidth="125.0" style="-fx-background-radius: 0 15 15 0;" text="Add ingredient" textFill="#697568">
               <font>
                  <Font name="Avenir Next Condensed Bold" size="13.0" />
               </font>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </Button>
         </children>
      </Pane>
   </children>
</AnchorPane>
